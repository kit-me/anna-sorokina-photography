    <!-- MODAL -->
    <div class="modal" id="modal">
        <button class="modal-close" onclick="closeModal()">✕</button>
        <div class="modal-content">
            <img class="modal-image" src="" alt="Full size image">
        </div>
    </div>

    <script>
        // Language Toggle
        const langToggle = document.querySelector('.lang-toggle');
        let isUkrainian = false;
        
        function updateLanguage() {
            document.documentElement.lang = isUkrainian ? 'uk' : 'en';
            
            // Update all elements with data-lang
            document.querySelectorAll('[data-lang]').forEach(el => {
                const lang = el.getAttribute('data-lang');
                const shouldShow = isUkrainian ? lang === 'uk' : lang === 'en';
                
                if (shouldShow) {
                    el.style.display = '';
                    el.removeAttribute('hidden');
                } else {
                    el.style.display = 'none !important';
                    el.setAttribute('hidden', '');
                }
            });
            
            langToggle.textContent = isUkrainian ? 'EN' : 'UA';
            localStorage.setItem('lang', isUkrainian ? 'uk' : 'en');
        }
        
        langToggle.addEventListener('click', () => {
            isUkrainian = !isUkrainian;
            updateLanguage();
        });
        
        // Initialize with saved language
        const savedLang = localStorage.getItem('lang');
        if (savedLang === 'uk') {
            isUkrainian = true;
            updateLanguage();
        }

        // Mobile Menu Toggle
        const menuToggle = document.querySelector('.menu-toggle');
        const nav = document.querySelector('nav');
        menuToggle.addEventListener('click', () => {
            nav.classList.toggle('active');
        });

        // Close menu when clicking on a link
        document.querySelectorAll('nav a').forEach(link => {
            link.addEventListener('click', () => {
                nav.classList.remove('active');
            });
        });

        // Modal Functions
        function openModal(element) {
            const modal = document.getElementById('modal');
            const modalImage = modal.querySelector('.modal-image');
            const img = element.querySelector('img');
            modalImage.src = img.src;
            modal.classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }

        document.getElementById('modal').addEventListener('click', (e) => {
            if (e.target.id === 'modal') closeModal();
        });

        // Booking Form
        function handleBooking(e) {
            e.preventDefault();
            const formData = new FormData(e.target);
            const message = `New Booking Inquiry:
Name: ${formData.get('name')}
Email: ${formData.get('email')}
Phone: ${formData.get('phone')}
Session: ${formData.get('package')}
Date: ${formData.get('date')}
Message: ${formData.get('message')}`;

            // Open email client
            window.location.href = `mailto:mir12312@ukr.net?subject=Photography Booking Inquiry&body=${encodeURIComponent(message)}`;
            e.target.reset();
        }

        // Smooth scroll to active section
        window.addEventListener('scroll', () => {
            document.querySelectorAll('section').forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (window.pageYOffset >= sectionTop - 200 && window.pageYOffset < sectionTop + sectionHeight - 200) {
                    document.querySelectorAll('nav a').forEach(link => {
                        link.classList.remove('active');
                        if (link.getAttribute('href') === '#' + section.id) {
                            link.classList.add('active');
                        }
                    });
                }
            });
        });

        // Slideshow Functionality
        let currentSlide = 0;
        const slides = document.querySelectorAll('.hero-slide');
        const dots = document.querySelectorAll('.indicator-dot');
        const totalSlides = slides.length;
        let slideshowInterval;

        function showSlide(n) {
            slides.forEach(slide => slide.classList.remove('active'));
            dots.forEach(dot => dot.classList.remove('active'));
            
            slides[n].classList.add('active');
            dots[n].classList.add('active');
        }

        function nextSlide() {
            currentSlide = (currentSlide + 1) % totalSlides;
            showSlide(currentSlide);
            resetSlideshowTimer();
        }

        function previousSlide() {
            currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
            showSlide(currentSlide);
            resetSlideshowTimer();
        }

        function goToSlide(n) {
            currentSlide = n;
            showSlide(currentSlide);
            resetSlideshowTimer();
        }

        function autoSlide() {
            nextSlide();
        }

        function resetSlideshowTimer() {
            clearInterval(slideshowInterval);
            slideshowInterval = setInterval(autoSlide, 6000);
        }

        // Start slideshow on page load
        window.addEventListener('load', () => {
            slideshowInterval = setInterval(autoSlide, 6000);
        });

        // Stop slideshow when user is not on hero section
        document.addEventListener('scroll', () => {
            const hero = document.querySelector('.hero');
            const heroRect = hero.getBoundingClientRect();
            if (heroRect.bottom < 0 || heroRect.top > window.innerHeight) {
                clearInterval(slideshowInterval);
            } else {
                if (!slideshowInterval) {
                    slideshowInterval = setInterval(autoSlide, 6000);
                }
            }
        });
    </script>
</body>
</html>